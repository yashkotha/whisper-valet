# AudioDrop configuration — copied to config.env by setup.sh (edit that copy).
# Every setting is optional; the defaults shown are what you get without it.

# Where you drop files, and where per-clip result folders appear
#INBOX="$HOME/AudioDrop"
#OUTBOX="$HOME/AudioDrop/Processed"

# MacWhisper's bundled CLI (change only if the app lives elsewhere)
#MW="/Applications/MacWhisper.app/Contents/MacOS/mw"

# Speakers per clip: auto = detect per clip (works for any recording),
# N = force exactly N (more accurate when you KNOW the count), MIN-MAX = bound
# the range (e.g. 2-5 for panel recordings).
NUM_SPEAKERS=auto

# Optional speaker names, in order of first appearance. Applied only when the
# detected speaker count matches the number of names — otherwise speakers get
# generic "Speaker N" names. Example for interviews:
#LABELS="Interviewer,Responder"
LABELS=""

# Also render the harder-denoised cleaned_aggressive.mp3 variant (1 = yes)
AGGRESSIVE=1
# macOS notification when a clip starts/finishes (1 = yes)
NOTIFY=1
